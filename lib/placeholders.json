      "dataType": "string",
      "required": false,
      "example": "CO"
    },
    "zipCode": {
      "format": "{{user.zipCode}}",
      "description": "User ZIP/postal code",
      "dataType": "string",
      "required": false,
      "example": "80202"
    }
  },
