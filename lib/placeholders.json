{
  "user": {
    "firstName": {
      "format": "{{user.firstName}}",
      "description": "User first name",
      "dataType": "string",
      "required": true,
      "example": "John"
    },
    "lastName": {
      "format": "{{user.lastName}}",
      "description": "User last name",
      "dataType": "string",
      "required": true,
      "example": "Smith"
    },
