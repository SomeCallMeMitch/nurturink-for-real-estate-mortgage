import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

// Default settings if no record exists
const DEFAULT_SETTINGS = {
  leftColumnSpan: 5,
  centerColumnSpan: 3,
  rightColumnSpan: 4
};

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    
    // Verify user is authenticated and is super admin
    const user = await base44.auth.me();
    
    if (!user) {
      return Response.json({ error: 'Unauthorized: Authentication required' }, { status: 401 });
    }
    
    if (user.appRole !== 'super_admin') {
      return Response.json({ error: 'Unauthorized: Super admin access required' }, { status: 403 });
    }
    
    // Parse request body
    const body = await req.json();
    
    // Validate that columns add up to 12
    const total = (body.leftColumnSpan || 0) + (body.centerColumnSpan || 0) + (body.rightColumnSpan || 0);
    if (total !== 12) {
      return Response.json(
        { error: `Column spans must add up to 12 (current total: ${total})` },
        { status: 400 }
      );
    }
    
    // Validate ranges
    if (body.leftColumnSpan < 1 || body.leftColumnSpan > 12 ||
        body.centerColumnSpan < 1 || body.centerColumnSpan > 12 ||
        body.rightColumnSpan < 1 || body.rightColumnSpan > 12) {
      return Response.json(
        { error: 'Each column span must be between 1 and 12' },
        { status: 400 }
      );
    }
    
    // Query for existing settings (singleton pattern)
    const settings = await base44.asServiceRole.entities.CreateContentLayoutSettings.list();
    
    // If no settings exist, create with provided data (or defaults)
    if (settings.length === 0) {
      const newSettings = await base44.asServiceRole.entities.CreateContentLayoutSettings.create({
        ...DEFAULT_SETTINGS,
        ...body
      });
      return Response.json(newSettings);
    }
    
    // Update existing record
    const updatedSettings = await base44.asServiceRole.entities.CreateContentLayoutSettings.update(
      settings[0].id,
      body
    );
    
    return Response.json(updatedSettings);
    
  } catch (error) {
    console.error('Error in updateCreateContentLayoutSettings:', error);
    return Response.json({ error: error.message }, { status: 500 });
  }
});