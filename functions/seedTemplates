Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    
    // Verify user is authenticated
    const user = await base44.auth.me();
    if (!user) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }
    
    if (!user.orgId) {
      return Response.json({ error: 'User must belong to an organization' }, { status: 400 });
    }
    
    // Check if any templates already exist for this organization
    const existingTemplates = await base44.entities.Template.filter({
      orgId: user.orgId
    });
    
    if (existingTemplates.length > 0) {
      return Response.json({
        success: false,
        message: `Templates already exist. Found ${existingTemplates.length} existing templates.`,
        templateCount: existingTemplates.length
      });
    }
    
    // Create all sample templates
    const createdTemplates = [];
    
    for (const sampleTemplate of sampleTemplates) {
      const template = await base44.entities.Template.create({
        ...sampleTemplate,
        createdByUserId: user.id,
        orgId: user.orgId
      });
      createdTemplates.push(template);
    }
    
    return Response.json({
      success: true,
      message: `Successfully created ${createdTemplates.length} templates!`,
      templateCount: createdTemplates.length,
      templates: createdTemplates
    });
    
  } catch (error) {
    console.error('Error in seedTemplates:', error);
    return Response.json(
      { 
        success: false,
        error: error.message || 'Failed to seed templates' 
      },
      { status: 500 }
    );
  }
});
