{
  "name": "Template",
  "description": "Message templates for automated card sends with placeholder support",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the template (e.g., 'Birthday - Default')",
      "required": true
    },
    "key": {
      "type": "string",
      "description": "Unique identifier for the template (e.g., 'birthday_default')",
      "required": true
    },
    "content": {
      "type": "string",
      "description": "Template content with placeholders like {{clientName}}, {{userFullName}}",
      "required": true
    },
    "category": {
      "type": "string",
      "description": "Category of template (e.g., 'Personal', 'Professional')",
      "required": false,
      "default": "Personal"
    },
    "cardDesign": {
      "type": "string",
      "description": "Card design to use (e.g., 'Thank you - Plain White')",
      "required": true,
      "default": "Thank you - Plain White"
    },
    "noteStyle": {
      "type": "string",
      "enum": ["casual", "professional", "formal"],
      "description": "Style profile for the note",
      "required": true,
      "default": "casual"
    },
    "tone": {
      "type": "string",
      "enum": ["casual", "professional", "formal", "warm", "grateful"],
      "description": "Tone of the message",
      "required": false,
      "default": "casual"
    },
    "description": {
      "type": "string",
      "description": "Description of when to use this template",
      "required": false
    },
    "isDefault": {
      "type": "boolean",
      "description": "Whether this is a default template provided by NurturInk",
      "required": false,
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "description": "Whether this template is available for use",
      "required": true,
      "default": true
    },
    "placeholders": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of available placeholders (e.g., ['clientName', 'userFullName', 'clientCompany'])",
      "required": false
    },
    "sortOrder": {
      "type": "integer",
      "description": "Display order in UI",
      "required": false,
      "default": 0
    }
  }
}
